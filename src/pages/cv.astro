---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const cvEntry = await getEntry('cv', 'cv');
if (!cvEntry) throw new Error('Missing src/data/cv.json entry with id "cv".');
const cv = cvEntry.data;

// "2024-01" -> "Jan 2024"; undefined -> "Present"
const formatMonth = (ym?: string): string => {
  if (!ym) return 'Present';
  const [y, m] = ym.split('-').map(Number);
  if (!y) return ym;
  if (!m) return String(y);
  return new Date(y, m - 1, 1).toLocaleDateString('en-US', {
    month: 'short',
    year: 'numeric',
  });
};
---

<BaseLayout title="Curriculum Vitae" description={cv.summary}>
  <div class="cv">
    <header class="cv__head">
      <h1 class="cv__title">Curriculum Vitae</h1>
      <p class="cv__summary">{cv.summary}</p>
    </header>

    <section class="cv__section">
      <div class="cv__section-label">Experience</div>
      <div>
        {
          cv.experience.map((job) => (
            <div class="cv__job">
              <div class="cv__job-head">
                <div>
                  <h3 class="cv__role">{job.role}</h3>
                  <div class="cv__org">
                    {job.company}
                    {job.location && ` · ${job.location}`}
                  </div>
                </div>
                <div class="cv__dates">
                  {formatMonth(job.startDate)} — {formatMonth(job.endDate)}
                </div>
              </div>
              <ul class="cv__bullets">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="cv__section">
      <div class="cv__section-label">Education</div>
      <div>
        {
          cv.education.map((e) => (
            <div class="cv__job">
              <div class="cv__job-head">
                <div>
                  <h3 class="cv__role">
                    {e.degree}
                    {e.field && `, ${e.field}`}
                  </h3>
                  <div class="cv__org">{e.institution}</div>
                </div>
                <div class="cv__dates">
                  {formatMonth(e.startDate)} — {formatMonth(e.endDate)}
                </div>
              </div>
              {e.notes && <p class="cv__notes">{e.notes}</p>}
            </div>
          ))
        }
      </div>
    </section>

    <section class="cv__section">
      <div class="cv__section-label">Skills</div>
      <dl class="cv__skills">
        {
          cv.skills.map((group) => (
            <div class="cv__skill-row">
              <dt>{group.category}</dt>
              <dd>{group.items.join(' · ')}</dd>
            </div>
          ))
        }
      </dl>
    </section>
  </div>
</BaseLayout>

<style>
  .cv {
    max-width: 880px;
    margin: 0 auto;
  }
  .cv__head {
    padding-bottom: 56px;
    margin-bottom: 56px;
    border-bottom: 1px solid var(--rule);
  }
  .cv__title {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(48px, 7vw, 88px);
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 0 0 28px;
  }
  .cv__summary {
    font-family: var(--body);
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-dim);
    max-width: 60ch;
    margin: 0;
    text-wrap: pretty;
  }
  .cv__section {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 56px;
    padding: 40px 0;
    border-top: 1px solid var(--rule);
  }
  .cv__section-label {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding-top: 4px;
  }
  .cv__job + .cv__job {
    margin-top: 36px;
    padding-top: 36px;
    border-top: 1px solid var(--rule);
  }
  .cv__job-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .cv__role {
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    margin: 0;
  }
  .cv__org {
    font-family: var(--ui);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-dim);
    margin-top: 4px;
  }
  .cv__dates {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
    text-transform: uppercase;
    white-space: nowrap;
  }
  .cv__notes {
    color: var(--ink-dim);
    margin: 0;
    font-size: 16px;
  }
  .cv__bullets {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cv__bullets li {
    padding-left: 22px;
    position: relative;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-dim);
    margin-bottom: 10px;
    text-wrap: pretty;
  }
  .cv__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 10px;
    height: 1px;
    background: var(--accent);
  }
  .cv__skills {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin: 0;
  }
  .cv__skill-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 24px;
    font-size: 14px;
  }
  .cv__skill-row dt {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .cv__skill-row dd {
    margin: 0;
    font-family: var(--body);
    color: var(--ink);
    font-size: 15px;
  }
  @media (max-width: 880px) {
    .cv__section {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>
