---
import type { CollectionEntry } from 'astro:content';
import { formatDateShort } from '../lib/date';
import { readingTime } from '../lib/readingTime';

interface Props {
  article: CollectionEntry<'articles'>;
}
const { article } = Astro.props;
const { title, description, pubDate } = article.data;
---

<a class="article-row" href={`/articles/${article.id}`}>
  <div class="article-row__date">{formatDateShort(pubDate)}</div>
  <div>
    <h2 class="article-row__title">{title}</h2>
    <p class="article-row__dek">{description}</p>
  </div>
  <div class="article-row__meta">{readingTime(article.body)}</div>
</a>

<style>
  .article-row {
    display: grid;
    grid-template-columns: 110px 1fr auto;
    gap: 32px;
    padding: 32px 0;
    border-bottom: 1px solid var(--rule);
    align-items: baseline;
    cursor: pointer;
    transition: padding 0.25s ease;
  }
  .article-row:hover {
    padding-left: 12px;
  }
  .article-row:hover .article-row__title {
    color: var(--accent);
  }
  .article-row__date {
    font-family: var(--ui);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .article-row__title {
    font-family: var(--display);
    font-size: clamp(24px, 2.2vw, 32px);
    line-height: 1.2;
    margin: 0 0 10px;
    font-weight: 400;
    transition: color 0.18s ease;
  }
  .article-row__dek {
    font-family: var(--body);
    color: var(--ink-dim);
    max-width: 60ch;
    font-size: 16px;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }
  .article-row__meta {
    font-family: var(--ui);
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: right;
    white-space: nowrap;
  }
  @media (max-width: 880px) {
    .article-row {
      grid-template-columns: 1fr;
      gap: 8px;
    }
    .article-row__meta {
      text-align: left;
    }
  }
</style>
